{
  "name": "aircraft-watcher",
  "version": "1.0.0",
  "description": "Polls ADS-B aircraft feed and sends SMS alerts via Twilio for interesting aircraft",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "test": "jest --forceExit"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "twilio": "^5.3.3"
  },
  "devDependencies": {
    "jest": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ]
  },
  "engines": {
    "node": ">=20"
  }
}
