{
  "name": "aircraft-watcher",
  "version": "1.0.0",
  "description": "Polls ADS-B aircraft feed and sends alerts for interesting aircraft",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
