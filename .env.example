# ─── Feed ────────────────────────────────────────────────────────────────────
# URL of the ADS-B aircraft JSON feed
AIRCRAFT_FEED_URL=https://airspace.prail.space/combine1090/data/aircraft.json

# How often to poll the feed (seconds)
POLL_INTERVAL_SEC=10

# ─── Alerting ─────────────────────────────────────────────────────────────────
# Minimum time between repeated alerts for the same aircraft (seconds)
# Default: 1200 (20 minutes)
ALERT_COOLDOWN_SEC=1200

# Safety cap on aircraft processed per poll cycle
MAX_AIRCRAFT_PER_POLL=500

# HTTP fetch timeout for the feed request (milliseconds)
FETCH_TIMEOUT_MS=15000

# ─── Watch list ───────────────────────────────────────────────────────────────
# Comma-separated tail numbers / registrations to alert on (case-insensitive)
# Example: N12345,G-ABCD,C-FABC
WATCH_TAILS=

# ─── Military heuristics ──────────────────────────────────────────────────────
# Set to false to disable military detection entirely
ENABLE_MILITARY_HEURISTICS=true

# Override default military callsign prefixes (comma-separated, uppercase)
# Leave blank to use built-in defaults
MIL_CALLSIGN_PREFIXES=

# ─── Twilio SMS ───────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_FROM=+15005550006
# Single number or comma-separated list
TWILIO_TO=+12025551234,+13105559876
